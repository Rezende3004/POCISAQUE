PORT=3000

# Recomendado quando a OPA estiver chamando a API pública.
# Envie o mesmo valor no header X-API-Key.
API_TEST_KEY=

# mock: permite testar o loop sem chave e sem custo.
# openai: utiliza a IA real e requer OPENAI_API_KEY.
AI_MODE=mock

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=25000
MAX_OUTPUT_TOKENS=220

# Memória temporária do servidor para o protótipo.
STATE_TTL_MS=21600000
IDEMPOTENCY_TTL_MS=86400000
RATE_LIMIT_PER_MINUTE=120
MAX_BODY_BYTES=1000000
